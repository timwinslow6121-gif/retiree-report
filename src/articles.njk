---
layout: page.njk
title: Articles
description: "Medicare and retirement articles from The Retiree Report."
permalink: /articles/
last_updated: ""
---
<section class="section">
  <div class="container content-width">
    <h1>Articles</h1>
    {% if collections.articles and collections.articles | length %}
      <ul style="list-style: none; padding: 0;">
        {% for post in collections.articles | reverse %}
          <li class="article-card" style="margin-bottom: 1.5rem;">
            <h2 class="article-card__title">
              <a href="{{ post.url }}">{{ post.data.title }}</a>
            </h2>
            <p class="article-card__meta">{{ post.date | readableDate }}</p>
          </li>
        {% endfor %}
      </ul>
    {% else %}
      <p>Articles coming soon.</p>
    {% endif %}
  </div>
</section>
